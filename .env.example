# Configuración de conexión a LM Studio
# Copia este archivo a .env y ajusta los valores según tu configuración

# Host donde corre LM Studio
LMSTUDIO_HOST=localhost

# Puerto donde corre LM Studio
LMSTUDIO_PORT=1234

# Modelo a usar (opcional - usa el modelo cargado por defecto si no se especifica)
# LMSTUDIO_MODEL=qwen2-vl-2b-instruct

# Timeout en segundos para respuestas del modelo
LMSTUDIO_TIMEOUT=60
